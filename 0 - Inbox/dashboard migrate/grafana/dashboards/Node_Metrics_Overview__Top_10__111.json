              "type": "prometheus",
              "uid": "f4V_TpTHk"
            },
            "expr": "topk(10, sum(label_replace(1 - sum(rate(node_cpu_seconds_total{mode=\"idle\"}[1m])) by (instance) / sum(rate(node_cpu_seconds_total[1m])) by (instance), \"host_ip\", \"$1\", \"instance\", \"(.*):.*\")) by (host_ip))",
            "format": "table",
            "instant": true,
            "refId": "B"
